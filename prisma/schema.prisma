generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("owner")
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  tech        String[]
  createdAt   DateTime @default(now())

  // GitHub sync
  githubOwner String?
  githubRepo  String?
  githubUrl   String?
  hidden      Boolean  @default(false)

  // Public "Explore" button (deployment URL controlled from admin)
  exploreUrl  String?

  // Private deployment vault (optional)
  deploymentVault DeploymentVaultProject?

  @@unique([githubOwner, githubRepo])
}

model DeploymentVaultProject {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status        String   @default("live") // live | paused | archived
  productionUrl String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credentials   VaultCredential[]
}

model VaultCredential {
  id             String   @id @default(cuid())
  vaultProjectId String
  vaultProject   DeploymentVaultProject @relation(fields: [vaultProjectId], references: [id], onDelete: Cascade)

  label          String   // e.g. "Mapbox token", "Cloudflare R2 key"
  kind           String   // api_key | upi | card | account | db | hosting | other
  provider       String?  // mapbox | cloudflare | vercel | neon | etc

  // Non-secret context fields
  identifier     String?  // email/username/accountId
  metaJson       String?  // JSON string for flexible provider fields (limits, notes, etc.)

  // Encrypted secret payload (AES-GCM)
  secretEnc      String?  // base64(ciphertext)
  secretIv       String?  // base64(iv)
  secretTag      String?  // base64(authTag)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([vaultProjectId])
}

model BillingRecord {
  id         String   @id @default(cuid())
  userId     String
  usage      Int
  costCents  Int
  recordedAt DateTime @default(now())

  @@index([userId])
}

model ApiLog {
  id        String   @id @default(cuid())
  route     String
  method    String
  status    Int
  createdAt DateTime @default(now())
}

model VisitorEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // What page was viewed
  path      String

  // Best-effort client info
  referrer  String?
  tz        String?
  lang      String?

  // Best-effort network info
  ip        String?
  userAgent String?

  // Coarse geo injected by hosting provider (e.g. Vercel). Null locally.
  country   String?
  region    String?
  city      String?

  @@index([createdAt])
  @@index([country])
}
